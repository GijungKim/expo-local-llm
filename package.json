{
  "name": "expo-local-llm",
  "version": "0.4.0",
  "description": "Expo module for on-device LLM inference via Apple Foundation Models (iOS) and Gemini Nano (Android)",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "src",
    "ios",
    "android",
    "expo-module.config.json"
  ],
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepare": "chmod +x node_modules/expo-module-scripts/bin/expo-module-* 2>/dev/null || true",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-local-llm",
    "llm",
    "on-device",
    "apple-intelligence",
    "gemini-nano",
    "foundation-models"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GijungKim/expo-local-llm"
  },
  "bugs": {
    "url": "https://github.com/GijungKim/expo-local-llm/issues"
  },
  "author": "GijungKim <tonykim970@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/GijungKim/expo-local-llm#readme",
  "dependencies": {},
  "devDependencies": {
    "@types/react": "~19.2.14",
    "expo-module-scripts": "^56.0.2",
    "expo": "^57.0.0",
    "react-native": "0.86.0"
  },
  "jest": {
    "preset": "jest-expo/node"
  },
  "peerDependencies": {
    "expo": ">=52.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  }
}
